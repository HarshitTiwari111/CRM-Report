PORT=5002
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/crm-report-local
CLIENT_URL=http://localhost:5173

JWT_SECRET=changeme_access_secret
JWT_REFRESH_SECRET=changeme_refresh_secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# SameSite policy for the HttpOnly refresh-token cookie.
# 'lax' (default) when client and API share an origin (or via dev proxy).
# 'none' when the client is served from a different domain than the API
# (e.g. separate static site + API service) — requires HTTPS.
COOKIE_SAMESITE=lax

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@crm-report.local
